  "query": "\n        SELECT \n            sp.played_at,\n            sp.requested_by,\n            t.title,\n            t.source_url\n        FROM song_plays sp\n        JOIN tracks t ON sp.track_uuid = t.track_uuid\n        WHERE sp.requested_channel = $1\n        ORDER BY sp.played_at DESC\n        LIMIT 25\n        ",
