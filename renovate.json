{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitScope(deps)"
  ],
  "configMigration": true,
  "packageRules": [
    {
      "matchManagers": [
        "cargo"
      ],
      "env": {
        "RUSTUP_TOOLCHAIN": "nightly"
      }
    }
  ]
}